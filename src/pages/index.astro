---
import { getCollection } from "astro:content";
import ExperienceCard from "@components/ExperienceCard.astro";
import Hero from "@components/Hero.astro";
import NoteCard from "@components/NoteCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import Section from "@components/Section.astro";
import SkillCard from "@components/SkillCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { experience } from "@data/experience";
import { languages, skills } from "@data/skills";
import { projects } from "@data/projects";

const notes = (await getCollection("notes")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const referralPacket = {
  targetRoles: [
    "Software Engineer, Backend Systems",
    "Software Engineer, AI Infrastructure",
    "Software Engineer, Cloud / Platform",
    "Software Engineer, Search / Ranking / ML Infrastructure"
  ],
  locations: "Zurich, Munich, London, Dublin, US. Open to relocation.",
  evidence: [
    "Production LLM service with async streaming, evaluation gates, and observability",
    "High-throughput FastAPI data platform",
    "Distributed multi-GPU data pipeline at Bosch",
    "Current Go/Kubernetes infrastructure project"
  ]
};
---

<BaseLayout>
  <main>
    <Hero />

    <Section
      id="referral"
      eyebrow="For referrals / recruiters"
      class="bg-white"
    >
      <div class="grid gap-5 lg:grid-cols-[1.05fr_0.8fr_1.2fr]">
        <article class="card">
          <h2 class="text-xl font-extrabold text-slate-950">Target roles</h2>
          <ul class="mt-5 grid gap-3 pl-5 text-sm leading-6 text-slate-700">
            {referralPacket.targetRoles.map((role) => <li class="list-disc marker:text-blue-700">{role}</li>)}
          </ul>
        </article>

        <article class="card">
          <h2 class="text-xl font-extrabold text-slate-950">Preferred locations</h2>
          <p class="mt-5 leading-7 text-slate-600">{referralPacket.locations}</p>
        </article>

        <article class="card">
          <h2 class="text-xl font-extrabold text-slate-950">Best evidence</h2>
          <ul class="mt-5 grid gap-3 pl-5 text-sm leading-6 text-slate-700">
            {referralPacket.evidence.map((item) => <li class="list-disc marker:text-blue-700">{item}</li>)}
          </ul>
        </article>
      </div>
    </Section>

    <Section
      id="featured"
      eyebrow="Featured projects"
    >
      <div class="grid gap-5 lg:grid-cols-2">
        {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </Section>

    <Section
      id="experience"
      eyebrow="Experience"
      class="bg-white"
    >
      <div class="grid gap-5">
        {experience.map((item) => <ExperienceCard item={item} />)}
      </div>
    </Section>

    <Section
      id="focus"
      eyebrow="Technical focus"
    >
      <div class="grid gap-5 md:grid-cols-2">
        {skills.map((skill) => <SkillCard skill={skill} />)}
      </div>
      <div class="mt-6 rounded-lg border border-line bg-white p-6">
        <h3 class="text-lg font-extrabold text-slate-950">Languages</h3>
        <div class="mt-4 flex flex-wrap gap-2">
          {languages.map((language) => <span class="tag">{language}</span>)}
        </div>
      </div>
    </Section>

    <Section
      id="notes"
      eyebrow="Writing / Notes"
      title="A public learning trail for systems thinking."
      description="Short practical notes that can grow over time. The point is to show how I reason about service design, release gates, and operational debugging."
      class="bg-white"
    >
      <div class="grid gap-5 md:grid-cols-3">
        {notes.map((note) => (
          <NoteCard
            title={note.data.title}
            summary={note.data.summary}
            date={note.data.date}
            tags={note.data.tags}
            href={`/notes/${note.slug}/`}
          />
        ))}
      </div>
    </Section>
  </main>
</BaseLayout>
