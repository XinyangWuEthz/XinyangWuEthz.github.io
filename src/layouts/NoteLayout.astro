---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
};

const { title, summary, date, tags } = Astro.props;
---

<BaseLayout title={`${title} | Xinyang Wu`} description={summary}>
  <main class="section-pad">
    <article class="page-shell">
      <a href="/notes/" class="text-sm font-bold text-blue-700 hover:text-blue-900">Back to notes</a>
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow">Technical note</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-normal text-slate-950 sm:text-5xl">{title}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{summary}</p>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-slate-500">
          <time datetime={date.toISOString()}>{date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</time>
          <span aria-hidden="true">/</span>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
      <div class="note-content mt-12">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
