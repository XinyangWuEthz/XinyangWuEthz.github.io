---
import { site } from "@data/site";
---

<footer class="border-t border-slate-200 bg-white">
  <div class="page-shell flex flex-col gap-4 py-8 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between">
    <p>Copyright {new Date().getFullYear()} {site.name}. Built as a static GitHub Pages portfolio.</p>
    <div class="flex flex-wrap gap-4">
      <a href="/engineering-focus/" class="font-semibold hover:text-blue-800">Engineering Focus</a>
      <a href={site.links.email} class="font-semibold hover:text-blue-800">Email</a>
      <a href={site.links.linkedin} class="font-semibold hover:text-blue-800">LinkedIn</a>
      <a href={site.links.github} class="font-semibold hover:text-blue-800">GitHub</a>
    </div>
  </div>
</footer>
