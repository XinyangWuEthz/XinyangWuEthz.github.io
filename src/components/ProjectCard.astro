---
import type { Project } from "@data/projects";

type Props = {
  project: Project;
  index: number;
};

const { project, index } = Astro.props;
const isPrimary = index === 0;
const evidenceLinks = [
  { label: "GitHub", url: project.repoUrl },
  { label: "Case Study", url: project.caseStudyUrl },
  { label: "Architecture", url: project.architectureUrl },
  { label: "Demo", url: project.demoUrl }
].filter((link): link is { label: string; url: string } => Boolean(link.url));
---

<article class={`card card-hover ${isPrimary ? "lg:col-span-2" : ""}`}>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <span class="eyebrow">Project {index + 1}</span>
    {project.status && (
      <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-800">
        Status: {project.status}
      </span>
    )}
  </div>
  <h3 class={`${isPrimary ? "text-2xl" : "text-xl"} mt-4 font-extrabold tracking-normal text-slate-950`}>
    {project.title}
  </h3>
  <p class="mt-3 leading-7 text-slate-600">{project.subtitle}</p>
  <ul class={`${isPrimary ? "md:grid-cols-2" : ""} mt-5 grid gap-3 pl-5 text-sm leading-6 text-slate-700`}>
    {project.bullets.map((bullet) => <li class="list-disc marker:text-blue-700">{bullet}</li>)}
  </ul>
  <div class="mt-6 flex flex-wrap gap-2">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  {evidenceLinks.length > 0 && (
    <div class="mt-6 flex flex-wrap gap-3" aria-label={`${project.title} evidence links`}>
      {evidenceLinks.map((link) => {
        const isExternal = link.url.startsWith("http");
        return (
          <a
            class="button button-secondary min-h-10 px-3"
            href={link.url}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  )}
</article>
