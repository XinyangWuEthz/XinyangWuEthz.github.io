---
import { site } from "@data/site";

const navItems = [
  { label: "Referral", href: "/#referral" },
  { label: "Projects", href: "/#featured" },
  { label: "Experience", href: "/#experience" },
  { label: "Focus", href: "/#focus" },
  { label: "Engineering", href: "/engineering-focus/" },
  { label: "Notes", href: "/#notes" }
];
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="page-shell flex min-h-16 items-center justify-between gap-6" aria-label="Primary navigation">
    <a href="/" class="text-base font-extrabold text-slate-950" aria-label="Xinyang Wu home">
      {site.name}
    </a>
    <div class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a class="rounded-md px-3 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-slate-950" href={item.href}>
          {item.label}
        </a>
      ))}
    </div>
    <a class="hidden rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-bold text-slate-900 hover:border-blue-300 hover:text-blue-800 sm:inline-flex" href={site.links.resume}>
      Resume
    </a>
  </nav>
</header>
