---
import { site } from "@data/site";
---

<section class="relative overflow-hidden border-b border-slate-200 bg-white">
  <div class="page-shell grid items-center gap-10 py-12 sm:py-14 lg:min-h-[calc(100svh-8rem)] lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
    <div>
      <p class="eyebrow">Software Engineer / AI Infrastructure / Backend Systems</p>
      <h1 class="mt-4 text-5xl font-extrabold leading-none tracking-normal text-slate-950 sm:text-6xl">
        Xinyang Wu
      </h1>
      <p class="mt-5 text-xl font-bold leading-7 text-slate-800">
        Software Engineer &middot; AI Infrastructure &middot; Backend Systems
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        ETH Z&uuml;rich MSc. Building production-grade Python/FastAPI systems, LLM/RAG services,
        data pipelines, observability, and now Go/Kubernetes infrastructure.
      </p>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
        Currently focused on Google L3 SWE readiness: distributed systems, backend engineering,
        Kubernetes, Go, and production AI platforms.
      </p>
      <div class="mt-8 flex flex-wrap gap-3" aria-label="Primary actions">
        <a class="button button-primary" href={site.links.projects}>View Projects</a>
        <a class="button button-secondary" href={site.links.resume}>Download Resume</a>
        <a class="button button-secondary" href={site.links.github}>GitHub</a>
        <a class="button button-secondary" href={site.links.linkedin}>LinkedIn</a>
        <a class="button button-secondary" href={site.links.email}>Email</a>
      </div>
    </div>
    <div class="relative hidden lg:block" aria-hidden="true">
      <div class="absolute -inset-8 rounded-full bg-blue-100/60 blur-3xl"></div>
      <div class="relative overflow-hidden rounded-lg border border-slate-200 bg-slate-950 shadow-soft">
        <img src="/infra-hero.png" alt="" class="h-[430px] w-full object-cover opacity-90" />
        <div class="absolute inset-0 bg-gradient-to-tr from-slate-950/10 via-transparent to-blue-950/20"></div>
      </div>
    </div>
  </div>
</section>
