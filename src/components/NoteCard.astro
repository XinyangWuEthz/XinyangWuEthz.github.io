---
type Props = {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  href: string;
};

const { title, summary, date, tags, href } = Astro.props;
---

<article class="card card-hover">
  <time class="text-sm font-bold text-slate-500" datetime={date.toISOString()}>
    {date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
  </time>
  <h3 class="mt-3 text-xl font-extrabold leading-tight text-slate-950">
    <a href={href} class="hover:text-blue-800">{title}</a>
  </h3>
  <p class="mt-3 leading-7 text-slate-600">{summary}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
</article>
