---
import type { Experience } from "@data/experience";

type Props = {
  item: Experience;
};

const { item } = Astro.props;
---

<article class="card">
  <div class="grid gap-2 md:grid-cols-[1fr_auto] md:items-start">
    <div>
      <h3 class="text-xl font-extrabold text-slate-950">{item.company} - {item.role}</h3>
      <p class="mt-2 text-sm font-semibold text-slate-500">{item.location}</p>
    </div>
    <p class="text-sm font-bold text-slate-500">{item.dates}</p>
  </div>
  <p class="mt-5 leading-7 text-slate-600">{item.summary}</p>
  <div class="mt-5">
    <p class="text-sm font-extrabold uppercase tracking-normal text-slate-500">SWE signals</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {item.signals.map((signal) => <span class="tag">{signal}</span>)}
    </div>
  </div>
  <div class="mt-5">
    <p class="text-sm font-extrabold uppercase tracking-normal text-slate-500">Highlights</p>
    <ul class="mt-3 grid gap-2 pl-5 text-sm leading-6 text-slate-700">
      {item.highlights.map((highlight) => <li class="list-disc marker:text-blue-700">{highlight}</li>)}
    </ul>
  </div>
</article>
