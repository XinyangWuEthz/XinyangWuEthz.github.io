---
type Props = {
  id: string;
  eyebrow: string;
  title: string;
  description?: string;
  class?: string;
};

const { id, eyebrow, title, description, class: className = "" } = Astro.props;
---

<section id={id} class={`section-pad ${className}`}>
  <div class="page-shell">
    <div class="mb-9 max-w-3xl">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-normal text-slate-950 sm:text-4xl">{title}</h2>
      {description && <p class="mt-4 text-lg leading-8 text-slate-600">{description}</p>}
    </div>
    <slot />
  </div>
</section>
